# IVR Studio Environment Variables
# Copy to .env and fill in your values

# ── FusionPBX PostgreSQL ──────────────────────────────────────────────────────
# When running via Docker: use the host machine's IP or host.docker.internal
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASSWORD=your_fusionpbx_db_password_here

# ── Secret Encryption Key ─────────────────────────────────────────────────────
# 32-byte hex string (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IVR_SECRET_KEY=your_64_char_hex_key_here

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
