# IVR Studio Environment Variables
# Copy to .env and fill in your values

# ── FusionPBX Server (SSH access for deploy.sh) ───────────────────────────────
FUSIONPBX_SSH=qaium@192.168.0.113
# SSH password (used by deploy.sh via sshpass if no key auth is set up)
FUSIONPBX_SSH_PASSWORD=Test123@

# ── FusionPBX PostgreSQL ──────────────────────────────────────────────────────
# API server connects to this from inside Docker or your local machine.
# deploy.sh connects via SSH and runs psql on the server itself (no port 5432 exposure needed).
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=fusionpbx
DB_USER=fusionpbx
DB_PASSWORD=d5PIZjYdWDFlVdIM7PO8HiANGw

# ── Secret Encryption Key ─────────────────────────────────────────────────────
# 32-byte hex string (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IVR_SECRET_KEY=0ba95e3be4795e27fe5824caccc78d69eea65a9c01d72b684ae8940609c4e668

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3002
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
